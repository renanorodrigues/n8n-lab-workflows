    {
      "parameters": {
        "jsCode": "// Pega todos os itens que entraram no nó\nconst items = $input.all();\n\n// Passa por cada item da lista e faz o processamento\nreturn items.map(item => {\n  // Pega o texto da propriedade 'output' do item atual\n  const raw = item.json.output;\n\n  if (!raw) {\n    return {\n      json: { name: 'Sem Nome', body: 'Conteúdo vazio' }\n    };\n  }\n\n  // Remove cercas de markdown tipo ```json ... ```\n  let cleaned = raw.trim()\n    .replace(/^```json\\s*/i, '')\n    .replace(/^```\\s*/i, '')\n    .replace(/```$/i, '')\n    .replace(/^\\uFEFF/, ''); // Remove BOM se existir\n\n  let parsedData;\n  try {\n    parsedData = JSON.parse(cleaned);\n  } catch (e) {\n    // Se um JSON falhar, ele avisa qual falhou sem derrubar todo o fluxo\n    parsedData = {\n      name: \"Erro de processamento\",\n      body: \"Não consegui fazer o parse deste item. Conteúdo original:\\n\" + cleaned\n    };\n  }\n\n  // Retorna o formato correto exigido pelo n8n para cada item\n  return {\n    json: {\n      name: parsedData.name || 'Sem nome',\n      body: parsedData.body || 'Sem conteúdo'\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1344,
